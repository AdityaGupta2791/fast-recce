# ─────────────────────────────────────────────────────────────
# FastRecce Backend — Environment Variables
# Copy this file to `.env` and fill in actual values.
# Never commit the real .env file.
# ─────────────────────────────────────────────────────────────

# --- Application ---
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# --- Database ---
# Matches docker-compose.yml defaults
DATABASE_URL=postgresql+asyncpg://fastrecce:fastrecce_dev@localhost:5432/fastrecce
DATABASE_ECHO=false
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- S3 / MinIO ---
# MinIO local dev defaults
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=fastrecce-snapshots
S3_REGION=us-east-1

# --- Auth ---
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_TO_RANDOM_HEX_STRING
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- External APIs ---
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
# Preview models have a "-preview" suffix. Common options as of 2026-04:
# gemini-3-flash-preview, gemini-3-pro-preview, gemini-2.5-flash, gemini-flash-latest
GEMINI_MODEL=gemini-3-flash-preview

# --- Rate limits ---
GOOGLE_PLACES_RATE_LIMIT_RPM=60
CRAWL_CONCURRENCY=5
CRAWL_TIMEOUT_SECONDS=30

# --- Airbnb scraping (Part 2 — plain HTTP via httpx, disabled by default) ---
# Master flag. Keep false in production; flip true locally for testing.
# Plain-HTTP scraping typically gets blocked after 20-50 requests; when that
# happens the search degrades gracefully to Google-Places-only.
AIRBNB_SCRAPE_ENABLED=false
# Minimum seconds between successive Airbnb listing fetches (jitter added).
AIRBNB_REQUEST_DELAY_SECONDS=5.0
# Hard cap on listings scraped per user search. Keep small to avoid bans.
AIRBNB_MAX_LISTINGS_PER_SEARCH=5

# --- MagicBricks scraping (Part 4 — same plain-HTTP approach, separate flag) ---
# Master flag. Default OFF; enable per-session for residential / generic
# searches. When both this and AIRBNB_SCRAPE_ENABLED are true, both sources
# fire in parallel via asyncio.gather.
MAGICBRICKS_SCRAPE_ENABLED=false
# Per-request polite delay (jitter added at runtime).
MAGICBRICKS_REQUEST_DELAY_SECONDS=5.0
# Hard cap on MagicBricks listings per search. MB listings turn over (410)
# frequently, so low cap is fine.
MAGICBRICKS_MAX_LISTINGS_PER_SEARCH=5
