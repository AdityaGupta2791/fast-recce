# ─────────────────────────────────────────────────────────────
# FastRecce Backend — Environment Variables
# Copy this file to `.env` and fill in actual values.
# Never commit the real .env file.
# ─────────────────────────────────────────────────────────────

# --- Application ---
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# --- Database ---
# Matches docker-compose.yml defaults
DATABASE_URL=postgresql+asyncpg://fastrecce:fastrecce_dev@localhost:5432/fastrecce
DATABASE_ECHO=false
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- S3 / MinIO ---
# MinIO local dev defaults
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=fastrecce-snapshots
S3_REGION=us-east-1

# --- Auth ---
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_TO_RANDOM_HEX_STRING
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- External APIs ---
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3-flash

# --- Rate limits ---
GOOGLE_PLACES_RATE_LIMIT_RPM=60
CRAWL_CONCURRENCY=5
CRAWL_TIMEOUT_SECONDS=30
